# Ardum reasons on 0G or it doesn't recommend. The matching agent runs
# on the 0G Compute Router; attestations live on 0G Storage; sessions
# persist in Supabase. There is no silent fallback to a local scorer —
# missing or failing 0G surfaces a clear error to the user.

# ─── 0G Storage ────────────────────────────────────────────────────────────
# Wallet-signed attestations are uploaded by /attest and read by
# /retreats + the matching agent. The private key funds upload gas.
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_PRIVATE_KEY=                                # funded wallet that pays upload gas

# ─── 0G Compute Router ─────────────────────────────────────────────────────
# Required. The matching agent calls /v1/chat/completions for every
# recommendation. If this group is missing or the call fails, the SSE
# stream yields an error event and the match page asks the user to
# retry — it does not downgrade to a deterministic scorer.
#
# Model choice matters on Vercel Hobby (25s Edge ceiling). Benchmarks
# against our real matching prompt (10 retreats, 800 max_tokens):
#   qwen3-vl-30b     ~6.0s end-to-end, no thinking, full JSON
#   deepseek-v4-flash ~22s+ — thinks for ~5s before any content tokens
#                       arrive; the stream times out on Hobby Edge.
#                       preserve_thinking:false doesn't help.
#   glm-5             returns empty content at 300-token budget (spends
#                       all tokens in hidden reasoning).
# qwen3-vl-30b is the safe default for the matching task on Hobby.
OG_COMPUTE_ROUTER_URL=https://router-api.0g.ai/v1            # mainnet
# OG_COMPUTE_ROUTER_URL=https://router-api-testnet.integratenetwork.work/v1  # testnet
OG_COMPUTE_API_KEY=
OG_COMPUTE_MODEL=qwen3-vl-30b                  # browse live catalog: GET /v1/models

# ─── Supabase (session persistence) ────────────────────────────────────────
# Sessions need to survive Vercel serverless cold-starts. Apply
# scripts/migrate-supabase.sql once to create the `sessions` table —
# without it, /api/profile will 500 on the first intake submit.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Client-safe vars (NEXT_PUBLIC_* are inlined at build time) ────────────
NEXT_PUBLIC_APP_NAME=Ardum
NEXT_PUBLIC_0G_CHAIN_ID=0G Galileo testnet

# ─── UXmaxx Hackathon: Practitioner booking (Magic + Particle UA) ──────────
# Magic creates the practitioner's embedded wallet via Google OAuth.
# Particle UA upgrades that EOA via EIP-7702 and routes cross-chain deposits.
# Demo repos: Particle-Network/ua-7702-magic-demo, universal-accounts-magic-wallet-api
MAGIC_API_KEY=
MAGIC_OIDC_PROVIDER_ID=                          # identity provider for OAuth login
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# ─── UXmaxx Hackathon: Operator attestation (Particle Auth + ZeroDev) ──────
# Operator signs in via Particle Auth; ZeroDev Kernel sponsors gas + session keys.
# ZeroDev + Particle doc: docs.zerodev.app/onboarding/particle
ZERODEV_RPC=                                     # from ZeroDev dashboard
# Particle Auth reuses the same NEXT_PUBLIC_PARTICLE_* vars above.

# ─── UXmaxx Hackathon: Drop-in class micropayments (Openfort + x402) ───────
# Openfort embedded wallet + x402 HTTP 402 payment protocol for per-class access.
# Recipe: openfort.io/docs/recipes/x402
OPENFORT_SECRET_KEY=
OPENFORT_BACKEND_WALLET_ID=                      # acc_... from Openfort dashboard
X402_FACILITATOR_URL=
NEXT_PUBLIC_OPENFORT_PUBLIC_KEY=                 # Openfort publishable key (client-safe)
NEXT_PUBLIC_OPENFORT_POLICY_ID=                  # gasless policy ID (client-safe)
