# Ardum runs in "demo mode" without any of these set: in-memory session,
# seed attestation pool, deterministic local matcher. Set the variables
# below to graduate to the real 0G + Supabase stack.

# ─── 0G Storage ────────────────────────────────────────────────────────────
# Leave blank for demo mode. With these set, /api/attestations POSTs will
# upload to 0G Storage instead of the local in-memory store.
# OG_RPC_URL=https://evmrpc-testnet.0g.ai
# OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# OG_PRIVATE_KEY=                                # funded wallet that pays upload gas

# ─── 0G Compute Router ─────────────────────────────────────────────────────
# Leave blank to use the deterministic local matcher. With these set, the
# matching agent will call the 0G Compute Router (OpenAI-compatible
# /v1/chat/completions) instead. If the LLM call fails, the agent falls
# back to the local scorer — the agentTrace.provider field records which
# path ran.
# OG_COMPUTE_ROUTER_URL=https://router-api.0g.ai/v1        # mainnet
# OG_COMPUTE_ROUTER_URL=https://router-api-testnet.integratenetwork.work/v1  # testnet
# OG_COMPUTE_API_KEY=
# OG_COMPUTE_MODEL=deepseek-v4-flash            # browse live catalog: GET /v1/models

# ─── Supabase (optional, for persistence across restarts) ──────────────────
# Leave blank to use the in-memory session store at src/lib/session.memory.ts
# (selected by the dispatcher at src/lib/session.ts). With these set, the
# dispatcher switches to src/lib/session.supabase.ts and persists across
# Vercel serverless cold-starts. Run scripts/migrate-supabase.sql once to
# create the `sessions` table.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Client-safe vars (NEXT_PUBLIC_* are inlined at build time) ────────────
NEXT_PUBLIC_APP_NAME=Ardum
# Chain ID shown in the wallet prompt and error messages. The hex 0x40d9
# (16661) is the 0G Galileo testnet placeholder — replace with your network
# if you're on a different one.
NEXT_PUBLIC_0G_CHAIN_ID=0G Galileo testnet
